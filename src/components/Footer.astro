---
const flagImage = "https://raw.githubusercontent.com/abqoryme/astro-cv/refs/heads/main/src/assets/gl_flag_128x.png";
const getYear = () => new Date().getFullYear().toString();
---

<footer class="flex justify-center items-center bg-transparent py-4">
  <p class="flex items-center text-center font-light text-sm text-secondary">
    &copy; {getYear()} developed by
    <a
      target="_blank"
      class="link ml-1"
      href="https://github.com/abqoryme"
      rel="noopener noreferrer">𝒜𝒷𝓆𝑜𝓇𝓎 𝒹𝑒𝓋</a
    >
  </p>
  <Img
    class="rounded-full w-4 h-4 ml-2 shadow-md border border-black"
    src={flagImage}
    alt="Indonesian Flag"
    width={16}
    height={16}
  />
</footer>
